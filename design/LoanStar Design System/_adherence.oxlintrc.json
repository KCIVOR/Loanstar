{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/loan/**",
              "components/navigation/**",
              "ui_kits/admin-dashboard/**",
              "ui_kits/auth/**",
              "ui_kits/borrower-portal/**",
              "ui_kits/loan-application/**",
              "ui_kits/staff-operations/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|children|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: variant, title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:success|warning|error|info)$/]",
        "message": "<Alert> variant must be one of 'success' | 'warning' | 'error' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|status|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, status, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:registered|pending|submitted|approved|active|denied|overdue|closed)$/]",
        "message": "<Badge> status must be one of 'registered' | 'pending' | 'submitted' | 'approved' | 'active' | 'denied' | 'overdue' | 'closed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|loading|disabled|fullWidth|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, loading, disabled, fullWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost|danger|success)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost' | 'danger' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:base|highlight|warning|danger|gradient)$/]",
        "message": "<Card> variant must be one of 'base' | 'highlight' | 'warning' | 'danger' | 'gradient'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChecklistDocument'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|filename|status|key|ref|className|style|children)$/]",
        "message": "<ChecklistDocument> doesn't accept that prop. Declared props: name, filename, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChecklistDocument'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:pending|uploaded|confirmed)$/]",
        "message": "<ChecklistDocument> status must be one of 'pending' | 'uploaded' | 'confirmed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|error|helper|prefix|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, required, error, helper, prefix, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|children|footer|width|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: open, onClose, title, children, footer, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<SidebarNavItem> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='SignatureConfirm'] > JSXAttribute > JSXIdentifier[name!=/^(?:docName|docType|signed|signedAt|onSign|key|ref|className|style|children)$/]",
        "message": "<SignatureConfirm> doesn't accept that prop. Declared props: docName, docType, signed, signedAt, onSign."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusTimeline'] > JSXAttribute > JSXIdentifier[name!=/^(?:steps|currentIndex|denied|key|ref|className|style|children)$/]",
        "message": "<StatusTimeline> doesn't accept that prop. Declared props: steps, currentIndex, denied."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:steps|currentIndex|onStepClick|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: steps, currentIndex, onStepClick."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
